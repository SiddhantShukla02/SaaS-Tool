# ═══════════════════════════════════════════════════════════════════════
# SaaS for Blog — .env.template
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env and fill in. Never commit .env to Git.
#
# Usage:
#   cp .env.template .env
#   # then edit with your editor
# ═══════════════════════════════════════════════════════════════════════

# ── App secrets (REQUIRED) ─────────────────────────────────────────
SAAS_PASSWORD=pick_a_long_random_password
# Password your team will enter at the login screen.
# Minimum 16 chars recommended. Shared across the team.

# ── Pipeline API keys (REQUIRED — same as your existing .env) ─────
SERP_API_KEY=
GEMINI_API_KEY=
FIRECRAWL_API_KEY=
BRAVE_API_KEY=

# ── Backend selection ──────────────────────────────────────────────
SAAS_QUEUE_BACKEND=thread
# Options:
#   thread  — in-process threading (single-machine dev, no Redis needed)
#   rq      — Redis Queue (production, multi-machine-safe, needs REDIS_URL)

# ── Redis (REQUIRED if SAAS_QUEUE_BACKEND=rq) ─────────────────────
REDIS_URL=redis://localhost:6379
# On Railway: leave blank; Railway injects this automatically when you add
# a Redis plugin.
# On docker-compose: redis://redis:6379 (matches service name in compose)

# ── Database path ──────────────────────────────────────────────────
SAAS_DB_PATH=runs.db
# Path to the SQLite state database. On Railway with a volume mount,
# set to /data/runs.db so it survives deploys.

# ── Dev-only bypass ────────────────────────────────────────────────
# SAAS_ALLOW_NO_AUTH=1
# ⚠️  Set to 1 ONLY for local dev without a password.
# Never set in production — leaves your URL open to the world.
